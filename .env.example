# Copy this file to .env and fill in real values. Never commit the populated .env.

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# S3 / MinIO object store
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=changeme
S3_SECRET_KEY=changeme
S3_BUCKET=lakehouse

# Iceberg
ICEBERG_WAREHOUSE_PATH=s3a://lakehouse/warehouse
